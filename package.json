{
    "name": "social-media-app",
    "version": "1.0.0",
    "private": true,
    "description": "Full-stack social media app with FastAPI + React",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd node-backend && npm run dev",
        "dev:frontend": "cd UI && npm run dev",
        "install:all": "cd node-backend && npm install && cd ../UI && npm install"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@vitest/coverage-v8": "^4.1.0",
        "concurrently": "^8.2.2",
        "jsdom": "^29.0.0",
        "vitest": "^4.1.0"
    }
}
